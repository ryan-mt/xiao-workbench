{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xiao Workbench Beta",
  "identifier": "com.xiao.workbench.beta",
  "build": {
    "beforeDevCommand": "npm run dev:beta",
    "beforeBuildCommand": "npm run build:beta"
  },
  "app": {
    "windows": [
      {
        "title": "Xiao Workbench Beta",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/beta/generated/32x32.png",
      "icons/beta/generated/128x128.png",
      "icons/beta/generated/128x128@2x.png",
      "icons/beta/generated/icon.icns",
      "icons/beta/generated/icon.ico"
    ]
  }
}
