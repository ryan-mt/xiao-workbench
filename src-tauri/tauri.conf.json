{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xiao Workbench",
  "version": "26.7.23",
  "identifier": "com.xiao.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Xiao Workbench",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http: https: http://asset.localhost https://asset.localhost; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A focused desktop workbench for coding agents"
  }
}
